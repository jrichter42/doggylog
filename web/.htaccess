Options -Indexes

<Files "bootstrap_setup.txt">
  Require all denied
</Files>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} !^doggylog\.kimvosen\.de(?::(?:80|443))?$ [NC]
  RewriteRule ^ - [R=400,L]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://doggylog.kimvosen.de%{REQUEST_URI} [R=301,L,NE]
  RewriteRule ^(?:app|config|data|var)(?:/|$) - [F,L]
</IfModule>
